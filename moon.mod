name = "Luna-Flow/floating"

version = "0.4.0"

readme = "README.md"

repository = "https://github.com/Luna-Flow/floating"

license = "Apache-2.0"

keywords = [ "floating", "bigint", "numerics" ]

description = "Arbitrary-precision binary, decimal, and ball arithmetic for MoonBit, with checked operations and explicit numeric semantics."

import {
  "Luna-Flow/arithmetic@0.2.2",
  "Luna-Flow/luna-generic@0.3.3",
  "moonbitlang/x@0.4.46",
  "Luna-Flow/type_theory@0.2.0",
}

source = "src"
